# ============================================
# NetWeave — Environment Configuration
# ============================================

# Project
COMPOSE_PROJECT_NAME=netweave

# Nginx
NGINX_PORT=80

# API Gateway
API_GATEWAY_PORT=3000

# User Service
USER_SERVICE_PORT=5000

# Order Service
ORDER_SERVICE_PORT=4000

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=netweave_secret_2024
MONGO_USERS_DB=users_db
MONGO_ORDERS_DB=orders_db
MONGO_USERS_PORT=27020
MONGO_ORDERS_PORT=27021

# Redis
REDIS_PASSWORD=redis_secret_2024

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# cAdvisor
CADVISOR_PORT=8081

# Dashboard
DASHBOARD_PORT=8080
